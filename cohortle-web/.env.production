# Production Environment Variables
# This file ensures proper production configuration

# API Configuration for Production
NEXT_PUBLIC_API_URL=https://api.cohortle.com

# Email Verification (MVP Mode)
NEXT_PUBLIC_REQUIRE_EMAIL_VERIFICATION=false

# Disable development features
NODE_ENV=production

# Disable WebSocket connections
NEXT_PUBLIC_DISABLE_WEBSOCKET=true

# Analytics (Production)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-production-umami-id