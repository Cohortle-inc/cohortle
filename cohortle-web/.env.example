# API Configuration
# Base URL for the backend API (cohortle-api)
# Example: http://localhost:3001 for local development
# Example: https://api.cohortle.com for production
NEXT_PUBLIC_API_URL=http://localhost:3001

# Email Verification (MVP Mode)
# Set to 'false' to hide email verification banner for MVP
# Set to 'true' or remove to show verification banner
NEXT_PUBLIC_REQUIRE_EMAIL_VERIFICATION=false

# Analytics (Optional)
# Umami analytics website ID
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-umami-website-id
